{
  "name": "carteira-pcd-backend",
  "version": "1.0.0",
  "description": "Backend for GO Card PCD identification system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "reset-db": "node scripts/reset-database.js",
    "seed-db": "node scripts/seed-database.js",
    "backup-db": "node scripts/backup-database.js",
    "analyze-db": "node scripts/analyze-database.js",
    "init-db": "npm run reset-db && npm run seed-db"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dompurify": "^3.0.8",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsdom": "^23.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
